---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

import Logo from "./Logo.astro";

// The slim, mobile-first business card behind the founders' QR codes.
// Extra sections (e.g. Beatriz's publications) go in the default slot,
// between the bio card and the sign-off.
interface Props {
  name: string;
  role: string;
  photo: ImageMetadata;
  photoAlt: string;
  photoFocus?: string;
  saveHref: string;
  bioLabel: string;
  paragraphs: string[];
  tags: string[];
}

const {
  name,
  role,
  photo,
  photoAlt,
  photoFocus = "50% 50%",
  saveHref,
  bioLabel,
  paragraphs,
  tags,
} = Astro.props;

const email = "hi@siren-farm.com";
---

<div class='card-page'>
  <div class='card-col'>
    <!-- identity -->
    <div class='identity'>
      <Image
        src={photo}
        alt={photoAlt}
        widths={[312]}
        sizes='156px'
        class='portrait'
        style={`object-position: ${photoFocus};`}
      />
      <div class='identity-text'>
        <h1>{name}</h1>
        <p class='role'>{role}, Siren Farm</p>
        <div class='location'>
          <Logo tone='dark' class='location-leaf' />
          <span>Tondela, Portugal</span>
        </div>
      </div>
    </div>

    <!-- actions -->
    <div class='actions'>
      <a class='btn-solid' href={saveHref} target='_blank' rel='noopener'>
        Save my contact <span class='btn-arrow'>→</span>
      </a>
      <div class='actions-grid'>
        <a
          class='pill-green'
          href='https://www.linkedin.com/company/sirenagtech'
          target='_blank'
          rel='noopener'>LinkedIn</a
        >
        <a class='pill-green' href='/'>siren-farm.com</a>
      </div>
      <a
        class='pill-green'
        href='https://maps.app.goo.gl/WF9fXFpXYvbAiu5r8'
        target='_blank'
        rel='noopener'>Sítio do Poço, Caparosinha — Tondela</a
      >
    </div>

    <!-- bio -->
    <div class='white-card'>
      <p class='card-label'>{bioLabel}</p>
      {paragraphs.map((paragraph) => <p class='bio-text'>{paragraph}</p>)}
      <div class='chips'>
        {tags.map((tag) => <span>{tag}</span>)}
      </div>
    </div>

    <slot />

    <!-- quiet deck link + sign-off -->
    <div class='sign-off'>
      <a
        class='deck-link'
        href='https://drive.google.com/file/d/1ATCG0iaQp3XUftesxoo2_AIF_Jk7FrT6/view?usp=drive_link'
        target='_blank'
        rel='noopener'>View investor pitch deck →</a
      >
      <div class='sign-off-lockup'>
        <Logo tone='dark' class='sign-off-leaf' />
        <p>With love, from Tondela</p>
        <a href={`mailto:${email}`}>{email}</a>
      </div>
    </div>
  </div>
</div>

<style>
  .card-page {
    min-height: 100vh;
    background: var(--color-rum-swizzle);
    display: flex;
    justify-content: center;
    padding: calc(clamp(32px, 6vw, 64px) + env(safe-area-inset-top, 0px)) 20px
      calc(56px + env(safe-area-inset-bottom, 0px));
  }
  .card-col {
    width: 100%;
    max-width: 480px;
    display: flex;
    flex-direction: column;
    gap: 22px;
  }

  .identity {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
  }
  :global(.portrait) {
    display: block;
    width: 156px;
    height: 156px;
    object-fit: cover;
    border-radius: 50%;
    border: 3px solid var(--color-saffron-mango);
    box-shadow: 0 12px 50px rgba(31, 63, 55, 0.18);
  }
  .identity-text {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }
  .identity-text h1 {
    margin: 0;
    font-size: 36px;
    line-height: 1.1;
    color: var(--color-stromboli);
  }
  .role {
    margin: 0;
    font-size: 16px;
    line-height: 1.45;
    color: var(--color-aquamarine);
  }
  .location {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 4px;
  }
  .location :global(.location-leaf) {
    width: 22px;
  }
  .location span {
    font-family: var(--font-display);
    font-size: 15px;
    color: var(--color-te-papa-green);
  }

  .actions {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .actions-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }
  .btn-solid {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    min-height: 54px;
    padding: 12px 24px;
    border-radius: 999px;
    background: var(--color-stromboli);
    color: var(--color-rum-swizzle);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 18px;
    text-decoration: none;
    transition: filter 250ms ease;
  }
  .btn-solid:hover {
    filter: brightness(1.08);
  }
  .btn-solid:active {
    filter: brightness(0.97);
  }
  .btn-arrow {
    font-weight: 400;
  }
  .pill-green {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 10px 16px;
    border-radius: 999px;
    border: 1px solid rgba(47, 99, 87, 0.45);
    color: var(--color-te-papa-green);
    font-size: 15px;
    text-decoration: none;
    transition:
      background 250ms ease,
      color 250ms ease;
  }
  .pill-green:hover {
    background: var(--color-stromboli);
    color: var(--color-rum-swizzle);
  }

  .white-card {
    border-radius: 1.5rem;
    background: var(--color-white);
    box-shadow: 0 8px 60px rgba(31, 63, 55, 0.1);
    padding: 26px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .card-label {
    margin: 0;
    font-size: 12px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-aquamarine);
  }
  .bio-text {
    margin: 0;
    font-size: 15.5px;
    line-height: 1.55;
    color: var(--color-te-papa-green);
    text-wrap: pretty;
  }
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 4px;
  }
  .chips span {
    display: inline-flex;
    padding: 5px 14px;
    border-radius: 999px;
    border: 1px solid rgba(47, 99, 87, 0.35);
    color: var(--color-stromboli);
    font-size: 13px;
  }

  .sign-off {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    padding-top: 12px;
    text-align: center;
  }
  .deck-link {
    color: var(--color-stromboli);
    font-size: 14px;
    text-decoration: none;
    border-bottom: 2px solid rgba(47, 99, 87, 0.35);
    padding-bottom: 4px;
  }
  .sign-off-lockup {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }
  .sign-off-lockup :global(.sign-off-leaf) {
    width: 64px;
  }
  .sign-off-lockup p {
    margin: 0;
    font-size: 16px;
    line-height: 1.4;
    color: var(--color-te-papa-green);
  }
  .sign-off-lockup a {
    color: var(--color-stromboli);
    font-size: 15px;
    text-decoration: none;
  }
</style>
