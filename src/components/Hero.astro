---
import { Image } from "astro:assets";

import Logo from "./Logo.astro";
import heroField from "../assets/hero-field.jpg";
---

<section class='hero'>
  <!-- vivid aerial drone photo dissolving into the green page -->
  <div class='hero-photo'>
    <Image
      src={heroField}
      alt='Aerial view of the Siren Farm fields'
      widths={[768, 1280, 1920]}
      sizes='100vw'
      loading='eager'
      fetchpriority='high'
    />
    <div class='hero-tint'></div>
  </div>

  <!-- hero copy, sitting over the field below the horizon -->
  <div class='hero-copy'>
    <h1>Siren Farm</h1>
    <p>
      Siren is an outdoor medical cannabis project in Portugal that blends
      regenerative agriculture and advanced technology to produce high-quality
      fresh cannabis under INFARMED regulation.
    </p>
  </div>

  <!-- dark leaf mark below the copy — its lower branches tuck behind the cards -->
  <div class='hero-leaf'>
    <Logo tone='dark' class='hero-leaf-mark' />
  </div>
</section>

<style>
  /* no overflow:hidden here — the leaf must run past the section
     and tuck behind the frosted cards below */
  .hero {
    position: relative;
    width: 100%;
  }

  .hero-photo {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    /* extend under the iOS status bar (viewport-fit=cover) */
    height: calc(clamp(560px, 49.2vw, 850px) + env(safe-area-inset-top, 0px));
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
  }
  .hero-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 60%;
    display: block;
  }
  /* uniform green wash + soft top-center haze + curved bottom dissolve */
  .hero-tint {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        ellipse 85% 95% at 50% 0%,
        rgba(47, 99, 87, 0) 45%,
        rgba(47, 99, 87, 0.55) 63%,
        rgba(47, 99, 87, 0.9) 80%,
        #2f6357 94%
      ),
      radial-gradient(
        ellipse 68% 64% at 50% 0%,
        rgba(64, 135, 119, 0.3) 0%,
        rgba(64, 135, 119, 0) 72%
      ),
      linear-gradient(rgba(47, 99, 87, 0.4), rgba(47, 99, 87, 0.4));
  }

  .hero-copy {
    position: relative;
    z-index: 1;
    max-width: 1080px;
    margin: 0 auto;
    padding: calc(clamp(370px, 26.6vw, 460px) + env(safe-area-inset-top, 0px)) 24px 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .hero-copy h1 {
    margin: 0;
    font-size: clamp(40px, 5.5vw, 84px);
    line-height: 1.1;
    color: var(--color-putty);
  }
  .hero-copy p {
    margin: clamp(16px, 1.5vw, 24px) 0 0;
    max-width: 26em;
    font-size: clamp(16px, 1.85vw, 28px);
    line-height: 1.29;
    color: var(--color-white);
  }

  .hero-leaf {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: center;
    margin-top: clamp(20px, 3.5vw, 60px);
    margin-bottom: clamp(-118px, -6.8vw, -76px);
    pointer-events: none;
  }
  .hero-leaf :global(.hero-leaf-mark) {
    width: clamp(330px, 29vw, 500px);
  }
</style>
