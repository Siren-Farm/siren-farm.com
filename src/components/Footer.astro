---
import Logo from "./Logo.astro";

// "With love, from Tondela" · leaf · address. Gold leaf on the green home
// gradient; the About page flips it — dark-green leaf on the cream page.
interface Props {
  variant?: "green" | "cream";
}

const { variant = "green" } = Astro.props;
---

<footer class={`footer on-${variant}`}>
  <div class='footer-row'>
    <p>With love,<br />from Tondela</p>
    <div class='footer-leaf'>
      <Logo tone={variant === "green" ? "gold" : "dark"} class='footer-leaf-mark' />
    </div>
    <p class='footer-address'>Sítio do Poço, Caparosinha<br />Tondela Portugal</p>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    z-index: 2;
    width: 100%;
  }
  .on-green {
    background: linear-gradient(180deg, #2f6357 0%, #447368 100%);
    padding: clamp(56px, 7vw, 96px) 24px clamp(48px, 6vw, 72px);
  }
  .on-cream {
    padding: clamp(40px, 5vw, 72px) 24px clamp(48px, 6vw, 72px);
  }

  .footer-row {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
  }
  .footer-row p {
    margin: 0;
    flex: 1 1 200px;
    min-width: 180px;
    font-size: clamp(20px, 1.85vw, 28px);
    line-height: 1.3;
  }
  .on-green .footer-row p {
    color: var(--color-white);
  }
  .on-cream .footer-row p {
    color: var(--color-te-papa-green);
  }
  .footer-address {
    text-align: right;
  }
  .footer-leaf {
    flex: 0 0 auto;
  }
  /* the leaf scales with the viewport so it reads as an accent
     between the two text blocks rather than dominating the band */
  .footer-leaf :global(.footer-leaf-mark) {
    width: clamp(170px, 20.5vw, 354px);
  }

  @media (max-width: 760px) {
    .footer-row {
      flex-direction: column;
      justify-content: center;
    }
    .footer-row p {
      text-align: center;
      flex: 0 0 auto;
    }
    /* on stacked mobile the leaf stays proportionally larger */
    .footer-leaf :global(.footer-leaf-mark) {
      width: min(300px, 72vw);
    }
  }
</style>
